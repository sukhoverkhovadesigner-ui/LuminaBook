        function persistCurrentBookPage() {
            if (!currentBook) return;
            if (currentBook.builtIn) {
                if (!appData.builtinProgress) appData.builtinProgress = {};
                appData.builtinProgress[currentBook.id] = currentBook.currentPage;
            } else {
                for (var i = 0; i < appData.books.length; i++) {
                    if (appData.books[i].id === currentBook.id) {
                        appData.books[i].currentPage = currentBook.currentPage;
                        appData.books[i].lastRead = Date.now();
                        break;
                    }
                }
            }
        }

        function changeReaderEncoding() {
            if (!currentBook || !currentBook.rawBase64) return;
            var mode = document.getElementById('readerEncodingSelect').value;
            var buffer = base64ToArrayBuffer(currentBook.rawBase64);
            var decoded = currentBook.rawFormat === 'fb2' || /\.fb2$/i.test(currentBook.name || '') ? parseFb2(buffer, mode) : decodeBuffer(buffer, mode);
            var clean = normalizeBookText(decoded.text);
            currentBook.pages = splitIntoPages(clean, 900);
            currentBook.currentPage = 0;
            currentBook.encoding = decoded.encoding;
            persistCurrentBookPage();
            renderReaderPage();
            saveData();
        }

        function readerNextPage() {
            if (!currentBook || currentBook.currentPage >= currentBook.pages.length - 1) return;
            currentBook.currentPage++;
            persistCurrentBookPage();
            renderReaderPage();
            saveData();
        }

        function readerPrevPage() {
            if (!currentBook || currentBook.currentPage <= 0) return;
            currentBook.currentPage--;
            persistCurrentBookPage();
            renderReaderPage();
            saveData();
        }

        function changeFontSize(delta) {
            readerFontSize = Math.max(12, Math.min(28, readerFontSize + delta * 2));
            document.getElementById('readerContent').style.fontSize = readerFontSize + 'px';
        }

        // ===== UI UPDATE =====
        function updateUI() {
            document.getElementById('streakDisplay').textContent = appData.streak;
            document.getElementById('coinDisplay').textContent = appData.coins || 0;
            updateDinoDisplay();

            var goalPct = Math.min(100, (appData.todayMinutes / appData.dailyGoal) * 100);
            var fill = document.getElementById('goalProgressFill');
            fill.style.width = goalPct + '%';
            fill.classList.toggle('complete', goalPct >= 100);
            document.getElementById('goalCurrent').textContent = appData.todayMinutes + ' мин';
            document.getElementById('goalTarget').textContent = 'из ' + appData.dailyGoal + ' мин';

            document.getElementById('statTotal').textContent = formatMinutes(appData.totalMinutes);
            document.getElementById('statToday').textContent = appData.todayMinutes;
            document.getElementById('statStreak').textContent = appData.streak;
            document.getElementById('statDaysTotal').textContent = appData.totalReadingDays || (appData.readingDays ? appData.readingDays.length : 0);

            renderCharts();
            renderHistory();
            renderAchievements();
            renderPetTasks();
            renderBooks();
            renderNotificationSettings();
        }

        function formatMinutes(total) {
            if (total < 60) return String(total);
            var h = Math.floor(total / 60);
            var m = total % 60;
            if (m === 0) return h + 'ч';
            return h + 'ч ' + m + 'м';
        }

        function renderCharts() {
            renderPeriodChart('weeklyChart', 7, false);
            renderPeriodChart('monthlyChart', 30, true);
        }

        function renderPeriodChart(containerId, count, monthMode) {
            var container = document.getElementById(containerId);
            var today = new Date();
            var maxVal = 1;
            var data = [];
            for (var i = count - 1; i >= 0; i--) {
                var d = new Date(today);
                d.setDate(d.getDate() - i);
                var key = d.toISOString().slice(0, 10);
                var val = appData.weeklyData[key] || 0;
                var label = monthMode ? String(d.getDate()) : ['Вс','Пн','Вт','Ср','Чт','Пт','Сб'][d.getDay()];
                data.push({ label: label, value: val, isToday: i === 0 });
                if (val > maxVal) maxVal = val;
            }
            var html = '';
            for (var j = 0; j < data.length; j++) {
                var item = data[j];
                var height = Math.max(4, (item.value / maxVal) * 100);
                var cls = item.isToday ? 'chart-bar today-bar' : 'chart-bar';
                html += '<div class="chart-bar-wrapper">' +
                    '<div class="chart-bar-value">' + (item.value > 0 && !monthMode ? item.value : '') + '</div>' +
                    '<div class="' + cls + '" style="height: ' + height + '%"></div>' +
                    '<div class="chart-bar-label">' + item.label + '</div>' +
                '</div>';
            }
            container.innerHTML = html;
        }

        function renderHistory() {
            var container = document.getElementById('historyList');
            var readingSessions = appData.sessions.filter(function(s) { return s.type === 'reading'; });

            if (readingSessions.length === 0) {
                container.innerHTML = '<div class="empty-state"><span class="empty-state-icon">📭</span><div class="empty-state-text">Пока нет сессий</div></div>';
                return;
            }

            var html = '';
            var limit = Math.min(20, readingSessions.length);
            for (var i = 0; i < limit; i++) {
                var s = readingSessions[i];
                var date = new Date(s.timestamp);
                var timeStr = date.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
                var dateStr = date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });
                html += '<div class="history-item">' +
                    '<div class="history-item-left">' +
                        '<div class="history-item-icon">📖</div>' +
                        '<div>' +
                            '<div class="history-item-time">' + timeStr + '</div>' +
                            '<div class="history-item-date">' + dateStr + '</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="history-item-minutes">' + s.minutes + ' мин</div>' +
                '</div>';
            }
            container.innerHTML = html;
        }

        // ===== ACHIEVEMENTS =====
        function checkAchievements() {
            var before = appData.unlockedAchievements.length;
            var newUnlocks = [];
            for (var i = 0; i < ACHIEVEMENTS.length; i++) {
                var ach = ACHIEVEMENTS[i];
                var checkFn = ACHIEVEMENT_CHECKS[ach.id];
                if (checkFn && appData.unlockedAchievements.indexOf(ach.id) === -1 && checkFn(appData)) {
                    appData.unlockedAchievements.push(ach.id);
                    newUnlocks.push(ach);
                }
            }
            if (before > 0 && !(appData.taskClaims && appData.taskClaims.first_reward)) {
                markTaskReady('first_reward');
                checkAllReadingTasksBonus();
                saveData();
            }
            if (newUnlocks.length > 0) {
                if (before === 0) {
                    markTaskReady('first_reward');
                    checkAllReadingTasksBonus();
                }
                saveData();
                newUnlocks.forEach(function(ach, idx) {
                    setTimeout(function() {
                        showToast(' Достижение: ' + ach.name + '!', true);
                    }, idx * 600);
                });
            }
        }

        function renderAchievements() {
            var container = document.getElementById('achievementsContainer');
            document.getElementById('achievementCount').textContent = appData.unlockedAchievements.length;
            document.getElementById('achievementTotal').textContent = ACHIEVEMENTS.length;

            // Group achievements by section
            var sections = {};
            for (var i = 0; i < ACHIEVEMENTS.length; i++) {
                var ach = ACHIEVEMENTS[i];
                if (!sections[ach.section]) sections[ach.section] = [];
                sections[ach.section].push(ach);
            }

            var html = '';
            for (var s = 0; s < SECTION_ORDER.length; s++) {
                var sectionName = SECTION_ORDER[s];
                if (!sections[sectionName]) continue;
                
                var sectionAchievements = sections[sectionName];
                
                // Section header centered with lines
                html += '<div class="achievement-section-header">';
                html += '<span class="achievement-section-title">' + sectionName.toUpperCase() + '</span>';
                html += '</div>';
                
                // Grid of achievements
                html += '<div class="achievements-grid">';
                for (var j = 0; j < sectionAchievements.length; j++) {
                    var ach = sectionAchievements[j];
                    var unlocked = appData.unlockedAchievements.indexOf(ach.id) !== -1;
                    html += '<div class="achievement-card ' + (unlocked ? 'unlocked' : '') + '">' +
                        '<div class="achievement-check">✓</div>' +
                        '<span class="achievement-icon">' + ach.icon + '</span>' +
                        '<div class="achievement-name">' + ach.name + '</div>' +
                        '<div class="achievement-desc">' + ach.desc + '</div>' +
                    '</div>';
                }
                html += '</div>';
            }
            
            container.innerHTML = html;
        }

        var notificationTimer = null;
        var notificationWatchTimer = null;
        var NOTIFICATION_TEXTS = [
            'Сейчас отличный момент, чтобы почитать ✨📖',
            'Идеальное время для книги! 📚✨',
            'Самое время для хорошей книги 📚',
            'Подари себе минуты чтения ✨🌟'
        ];

        function getNotificationText() {
            var dayIndex = Math.floor(Date.now() / 86400000);
            return NOTIFICATION_TEXTS[dayIndex % NOTIFICATION_TEXTS.length];
        }

        function renderNotificationSettings() {
            var input = document.getElementById('notificationTimeInput');
            if (!input) return;
            input.value = appData.notificationTime || '20:00';
            var status = document.getElementById('notificationStatus');
            var enabledBtn = document.getElementById('notificationEnableBtn');
            var disabledBtn = document.getElementById('notificationDisableBtn');
            var supported = 'Notification' in window;
            if (!supported) {
                status.textContent = appData.notificationsEnabled ? 'Системные уведомления недоступны, поэтому напоминание появится внутри страницы.' : 'Системные уведомления недоступны, но можно включить напоминание внутри страницы.';
                enabledBtn.disabled = appData.notificationsEnabled;
                disabledBtn.disabled = !appData.notificationsEnabled;
                return;
            }
            enabledBtn.disabled = appData.notificationsEnabled && Notification.permission === 'granted';
            disabledBtn.disabled = !appData.notificationsEnabled;
            if (appData.notificationsEnabled && Notification.permission === 'granted') {
                status.textContent = 'Напоминание включено на ' + (appData.notificationTime || '20:00') + '.';
            } else if (appData.notificationsEnabled) {
                status.textContent = 'Системные уведомления не разрешены, поэтому напоминание появится внутри страницы в ' + (appData.notificationTime || '20:00') + '.';
            } else if (Notification.permission === 'denied') {
                status.textContent = 'Уведомления запрещены в браузере. Разреши их в настройках сайта, если захочешь включить напоминания.';
            } else {
                status.textContent = 'Уведомления пока выключены. Они работают, пока эта страница открыта.';
            }
        }

        function saveNotificationTime() {
            var input = document.getElementById('notificationTimeInput');
            appData.notificationTime = input && input.value ? input.value : '20:00';
            saveData();
            renderNotificationSettings();
            scheduleReadingNotification();
        }

        function enableReadingNotifications() {
            if (!('Notification' in window)) {
                appData.notificationsEnabled = true;
                saveData();
                renderNotificationSettings();
                scheduleReadingNotification();
                showToast('Включены напоминания внутри страницы');
                return;
            }
            saveNotificationTime();
            Notification.requestPermission().then(function(permission) {
                if (permission === 'granted') {
                    appData.notificationsEnabled = true;
                    saveData();
                    renderNotificationSettings();
                    scheduleReadingNotification();
                    showToast('Уведомления включены');
                } else {
                    appData.notificationsEnabled = true;
                    saveData();
                    renderNotificationSettings();
                    scheduleReadingNotification();
                    showToast('Буду напоминать внутри страницы');
                }
            });
        }

        function disableReadingNotifications() {
            appData.notificationsEnabled = false;
            saveData();
            if (notificationTimer) clearTimeout(notificationTimer);
            if (notificationWatchTimer) clearInterval(notificationWatchTimer);
            notificationTimer = null;
            notificationWatchTimer = null;
            renderNotificationSettings();
            showToast('Уведомления выключены');
        }

        function scheduleReadingNotification() {
            if (notificationTimer) clearTimeout(notificationTimer);
            if (notificationWatchTimer) clearInterval(notificationWatchTimer);
            notificationTimer = null;
            notificationWatchTimer = null;
            if (!appData.notificationsEnabled) return;
            notificationWatchTimer = setInterval(checkReadingNotificationDue, 30000);
            checkReadingNotificationDue();
        }

        function getNotificationKeyForDate(date) {
            return date.toISOString().slice(0, 10) + '-' + (appData.notificationTime || '20:00');
        }

        function checkReadingNotificationDue() {
            if (!appData.notificationsEnabled) return;
            var parts = (appData.notificationTime || '20:00').split(':');
            var hours = parseInt(parts[0], 10);
            var minutes = parseInt(parts[1], 10);
            if (isNaN(hours) || isNaN(minutes)) return;
            var now = new Date();
            var due = new Date();
            due.setHours(hours, minutes, 0, 0);
            var diff = now.getTime() - due.getTime();
            if (diff >= 0 && diff < 5 * 60 * 1000) {
                showReadingNotification(false);
            }
        }

        function showReadingNotification(isTest) {
            var key = getNotificationKeyForDate(new Date());
            if (!isTest && appData.notificationLastKey === key) return;
            var message = getNotificationText();
            if ('Notification' in window && Notification.permission === 'granted') {
                try {
                    new Notification('LuminaRead', { body: message, tag: 'luminaread-reading-reminder', renotify: true });
                } catch (e) {
                    showToast(message);
                }
            } else {
                showToast(message);
            }
            if (!isTest) {
                appData.notificationLastKey = key;
                saveData();
            }
        }

        var ONBOARDING_STEPS = [
            { emoji: '🌟', title: 'Читай и расти свою Звезду', text: 'Твоя звезда будет эволюционировать от Искры до Сверхновой!' },
            { emoji: '✨', title: 'Выполняй задания', text: 'Ставь цели, выполняй их и получай за это Искры.' },
            { emoji: '📚', title: 'Читай книги из подборки и загружай свои', text: 'Открывай подборку интересных книг и загружай свои в удобных форматах: TXT, FB2, EPUB или PDF.' },
            { emoji: '⏱️', title: 'Ставь цели по чтению', text: 'Укажи время, которое хочешь читать, а потом засекай время или добавляй минуты вручную.' },
            { emoji: '🏆', title: 'Получай награды', text: 'Открывай достижения за чтение, серии, книги и рост твоей Звезды!' },
            { emoji: '📊', title: 'Следи за прогрессом', text: 'Изучай свою книжную статистику за неделю и месяц.' }
        ];
        var onboardingIndex = 0;

        function renderOnboarding() {
            var step = ONBOARDING_STEPS[onboardingIndex];
            document.getElementById('onboardingStep').textContent = (onboardingIndex + 1) + ' / ' + ONBOARDING_STEPS.length;
            document.getElementById('onboardingEmoji').textContent = step.emoji;
            document.getElementById('onboardingTitle').textContent = step.title;
            document.getElementById('onboardingText').textContent = step.text;
            document.getElementById('onboardingPrevBtn').style.visibility = onboardingIndex === 0 ? 'hidden' : 'visible';
            document.getElementById('onboardingNextBtn').textContent = onboardingIndex === ONBOARDING_STEPS.length - 1 ? 'Начать' : 'Дальше';
            var dots = '';
            for (var i = 0; i < ONBOARDING_STEPS.length; i++) {
                dots += '<span class="onboarding-dot ' + (i === onboardingIndex ? 'active' : '') + '"></span>';
            }
            document.getElementById('onboardingDots').innerHTML = dots;
        }

        function openOnboarding(force) {
            onboardingIndex = 0;
            renderOnboarding();
            document.getElementById('onboardingOverlay').classList.add('active');
            if (force) showToast('Онбординг открыт заново');
        }

        function closeOnboarding(markSeen) {
            document.getElementById('onboardingOverlay').classList.remove('active');
            if (markSeen) {
                appData.onboardingSeen = true;
                saveData();
            }
        }

        function nextOnboarding() {
            if (onboardingIndex >= ONBOARDING_STEPS.length - 1) {
                closeOnboarding(true);
                return;
            }
            onboardingIndex++;
            renderOnboarding();
        }

        function prevOnboarding() {
            if (onboardingIndex <= 0) return;
            onboardingIndex--;
            renderOnboarding();
        }

        // ===== TOAST =====
        function showToast(message, isAchievement) {
            var toast = document.getElementById('toast');
            toast.textContent = message;
            toast.className = 'toast show' + (isAchievement ? ' achievement' : '');
            setTimeout(function() {
                toast.classList.remove('show');
            }, 3000);
        }

        // ===== INIT =====
        function init() {
            appData = loadData();
            applyTheme();
            checkDayReset();

            // Nav tabs
            var navTabs = document.querySelectorAll('.nav-tab');
            for (var i = 0; i < navTabs.length; i++) {
                navTabs[i].addEventListener('click', function() {
                    var page = this.getAttribute('data-page');
                    for (var t = 0; t < navTabs.length; t++) {
                        navTabs[t].classList.remove('active');
                    }
                    this.classList.add('active');
                    var pages = document.querySelectorAll('.page');
                    for (var p = 0; p < pages.length; p++) {
                        pages[p].classList.remove('active');
                    }
                    document.getElementById('page-' + page).classList.add('active');
                    

                });
            }

            // Timer
            document.getElementById('timerBtn').addEventListener('click', toggleTimer);
            document.getElementById('resetBtn').addEventListener('click', resetTimer);

            // Quick add
            var quickBtns = document.querySelectorAll('.quick-btn');
            for (var j = 0; j < quickBtns.length; j++) {
                quickBtns[j].addEventListener('click', function() {
                    var min = parseInt(this.getAttribute('data-min'), 10);
                    quickAdd(min);
                });
            }

            // Custom add
            document.getElementById('customAddBtn').addEventListener('click', addCustomMinutes);
            document.getElementById('customMinutes').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') addCustomMinutes();
            });

            // Goal modal
            document.getElementById('goalEditBtn').addEventListener('click', openGoalModal);
            document.getElementById('goalSaveBtn').addEventListener('click', closeGoalModal);
            document.getElementById('goalCustomBtn').addEventListener('click', setCustomGoal);
            document.getElementById('goalCustomInput').addEventListener('keypress', function(e) {
                if (e.key === 'Enter') setCustomGoal();
            });
            document.getElementById('goalModal').addEventListener('click', function(e) {
                if (e.target === this) closeGoalModal();
            });

            var goalOptions = document.querySelectorAll('.goal-option');
            for (var k = 0; k < goalOptions.length; k++) {
                goalOptions[k].addEventListener('click', function() {
                    selectGoalOption(this);
                });
            }

            // File upload
            document.getElementById('uploadBtn').addEventListener('click', function() {
                document.getElementById('fileInput').click();
            });
            document.getElementById('fileInput').addEventListener('change', handleFileUpload);

            // Reader
            document.getElementById('readerBackBtn').addEventListener('click', closeReader);
            document.getElementById('readerNextBtn').addEventListener('click', readerNextPage);
            document.getElementById('readerPrevBtn').addEventListener('click', readerPrevPage);
            document.getElementById('fontDecBtn').addEventListener('click', function() { changeFontSize(-1); });
            document.getElementById('fontIncBtn').addEventListener('click', function() { changeFontSize(1); });
            document.getElementById('readerEncodingSelect').addEventListener('change', changeReaderEncoding);
            document.querySelectorAll('.chart-tab').forEach(function(tab) { tab.addEventListener('click', function() { document.querySelectorAll('.chart-tab').forEach(function(t) { t.classList.remove('active'); }); tab.classList.add('active'); document.getElementById('weeklyChart').style.display = tab.dataset.chart === 'week' ? 'flex' : 'none'; document.getElementById('monthlyChart').style.display = tab.dataset.chart === 'month' ? 'flex' : 'none'; }); });
            document.getElementById('onboardingReplayBtn').addEventListener('click', function() { openOnboarding(true); });
            document.getElementById('themeToggleBtn').addEventListener('click', toggleTheme);
            document.getElementById('onboardingSkipBtn').addEventListener('click', function() { closeOnboarding(true); });
            document.getElementById('onboardingNextBtn').addEventListener('click', nextOnboarding);
            document.getElementById('onboardingPrevBtn').addEventListener('click', prevOnboarding);
            document.getElementById('petTasks').addEventListener('click', function(e) {
                var card = e.target.closest('.task-card');
                if (!card || !card.classList.contains('ready')) return;
                claimTaskReward(card.getAttribute('data-task-id'), card.querySelector('.task-reward') || card);
            });
            document.getElementById('notificationTimeInput').addEventListener('change', saveNotificationTime);
            document.getElementById('notificationEnableBtn').addEventListener('click', enableReadingNotifications);
            document.getElementById('notificationDisableBtn').addEventListener('click', disableReadingNotifications);
            document.getElementById('notificationTestBtn').addEventListener('click', function() {
                if (!('Notification' in window)) {
                    showToast('Браузер не поддерживает уведомления');
                    return;
                }
                if (Notification.permission === 'granted') {
                    showReadingNotification(true);
                } else {
                    enableReadingNotifications();
                }
            });

            // Keyboard for reader
            document.addEventListener('keydown', function(e) {
                if (!document.getElementById('readerOverlay').classList.contains('active')) return;
                if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); readerNextPage(); }
                else if (e.key === 'ArrowLeft') { e.preventDefault(); readerPrevPage(); }
                else if (e.key === 'Escape') { closeReader(); }
            });

            updateUI();
            checkAchievements();
            scheduleReadingNotification();
            if (!appData.onboardingSeen) openOnboarding(false);
        }

        init();
    </script>
</body>
</html>


