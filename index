        function renderReaderPage() {
            if (!currentBook) return;

            var page = currentBook.pages[currentBook.currentPage];
            var content = document.getElementById('readerContent');

            var paragraphs = page.split('\n').filter(function(p) { return p.trim().length > 0; });
            var html = '';
            for (var i = 0; i < paragraphs.length; i++) {
                html += '<p>' + escapeHtml(paragraphs[i]) + '</p>';
            }
            content.innerHTML = html;

            document.getElementById('readerPageInfo').textContent = (currentBook.currentPage + 1) + ' / ' + currentBook.pages.length;

            var progress = ((currentBook.currentPage + 1) / currentBook.pages.length) * 100;
            document.getElementById('readerProgressFill').style.width = progress + '%';

            document.getElementById('readerPrevBtn').disabled = (currentBook.currentPage === 0);
            document.getElementById('readerNextBtn').disabled = (currentBook.currentPage >= currentBook.pages.length - 1);

            content.scrollTop = 0;
