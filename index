        }

        function updateDinoDisplay() {
            var growthDays = getGrowthDays(appData);
            var stage = getDinoStage(growthDays);
            document.getElementById('dinoStage').textContent = stage.emoji;
            document.getElementById('dinoName').textContent = stage.name;
            document.getElementById('dinoDaysBadge').textContent = appData.streak + ' дн.';

            var nextInfo = null;
            if (stage.index < DINO_STAGES.length - 1) {
                var next = DINO_STAGES[stage.index + 1];
                nextInfo = { name: next.name, daysNeeded: Math.max(0, next.days - growthDays), emoji: next.emoji };
            } else {
                nextInfo = { name: 'новый виток', daysNeeded: Math.max(0, STAR_TOTAL_DAYS - growthDays), emoji: '✨' };
            }

            if (nextInfo.daysNeeded > 0) {
                document.getElementById('dinoProgress').textContent = 'До "' + nextInfo.name + '": ' + nextInfo.daysNeeded + ' дн. роста';
            } else {
                document.getElementById('dinoProgress').textContent = 'Сверхновая сияет в полную силу!';
            }

            var progress = 0;
            if (stage.index >= DINO_STAGES.length - 1) {
                progress = Math.min(100, Math.max(0, ((growthDays - DINO_STAGES[stage.index].days) / DINO_STAGES[stage.index].duration) * 100));
            } else {
                var prevDays = DINO_STAGES[stage.index].days;
                var nextDays = DINO_STAGES[stage.index + 1].days;
                progress = Math.min(100, Math.max(0, ((growthDays - prevDays) / (nextDays - prevDays)) * 100));
            }
            document.getElementById('dinoGrowthFill').style.width = progress + '%';

            var stripEmoji = document.getElementById('petStripEmoji');
            if (stripEmoji) {
                stripEmoji.textContent = stage.emoji;
                document.getElementById('petStripName').textContent = stage.name;
