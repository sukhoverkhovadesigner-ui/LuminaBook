        // ===== READER =====

        function openPdfBook(book) {
            if (pdfSessionUrls[book.id]) {
                window.open(pdfSessionUrls[book.id], '_blank');
                showToast('PDF открыт в новой вкладке');
                return;
            }
            if (book.rawBase64) {
                var byteChars = atob(book.rawBase64);
                var bytes = new Uint8Array(byteChars.length);
                for (var i = 0; i < byteChars.length; i++) bytes[i] = byteChars.charCodeAt(i);
                var url = URL.createObjectURL(new Blob([bytes], { type: 'application/pdf' }));
                window.open(url, '_blank');
                setTimeout(function() { URL.revokeObjectURL(url); }, 60000);
                showToast('PDF открыт в новой вкладке');
            } else {
                showToast('PDF слишком большой для сохранения в браузере. Загрузите файл заново и откройте его отдельно.');
            }
        }

        function openBook(bookId) {
            var allBooks = getAllBooks();
