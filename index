        ];
        var STAR_TOTAL_DAYS = 66;

        var BUILT_IN_BOOKS = [
            { id: 'classic-prince', author: 'Никколо Макиавелли', title: 'Государь', tag: 'власть и холодный ум', emoji: '♟️', desc: 'Короткий трактат о власти, страхе, выгоде и цене политической трезвости.', text: 'Никколо Макиавелли — Государь\n\nВсякое государство и всякая власть, какие имели и имеют силу над людьми, были и суть либо республики, либо единодержавия. Новые владения труднее удержать, чем наследственные: люди охотно меняют господина, надеясь на лучшее, но вскоре узнают, что перемена часто приносит новые тяготы.\n\nГосударь должен понимать, что любовь народа ценна, но безопасность власти не может держаться на одной любви. Лучше, чтобы тебя и любили, и боялись; но если приходится выбирать, надежнее внушать страх, не переходящий в ненависть.\n\nВ делах власти судят по исходу. Поэтому правителю следует казаться милосердным, верным, человечным, искренним и благочестивым, но иметь дух, готовый действовать иначе, когда необходимость требует.' },
            { id: 'classic-oracle', author: 'Бальтасар Грасиан', title: 'Карманный оракул', tag: 'афоризмы стратегии', emoji: '🧭', desc: 'Афоризмы о самообладании, стратегии и искусстве держать дистанцию.', text: 'Бальтасар Грасиан — Карманный оракул\n\nВсе уже достигло зрелости, и более всего — искусство быть личностью. Мудрый не открывает себя сразу: пусть его узнают постепенно, чтобы интерес не иссяк раньше уважения.\n\nНе спорь с тем, кто ничего не теряет от своей неправоты. Не всякая победа нужна: иногда выигрывает тот, кто вовремя уходит от мелкого столкновения.\n\nДержи меру в надежде и страхе. Надежда делает путь светлее, страх делает шаг осторожнее; вместе они сохраняют достоинство решения.' },
            { id: 'classic-eristic', author: 'Артур Шопенгауэр', title: 'Искусство быть правым', tag: 'логика спора', emoji: '⚔️', desc: 'Ироничный набор спорных приемов, который помогает распознавать уловки.', text: 'Артур Шопенгауэр — Искусство быть правым\n\nДиалектика есть искусство вести спор так, чтобы остаться правым независимо от истины. Кто спорит, тот часто заботится не о правильности мысли, а о видимости победы.\n\nЕсли довод противника силен, можно перенести разговор на соседний вопрос, расширить утверждение до абсурда или потребовать доказательств там, где достаточно здравого смысла.\n\nЗнание этих приемов полезно не для обмана, а для защиты: заметив уловку, легче вернуть разговор к предмету и спросить, что именно доказано.' },
            { id: 'classic-dorian', author: 'Оскар Уайльд', title: 'Портрет Дориана Грея', tag: 'красота и расплата', emoji: '🪞', desc: 'Готическая история о красоте, желании и расплате за вечную молодость.', text: 'Оскар Уайльд — Портрет Дориана Грея\n\nМастерская была наполнена запахом роз, а легкий летний ветер шевелил занавески и приносил из сада теплую тишину. На мольберте стоял портрет юноши необыкновенной красоты.\n\nХудожник смотрел на него с тревогой человека, который вложил в работу больше, чем краски и мастерство. В лице Дориана было то безмятежное совершенство, которое кажется обещанием счастья, пока не станет испытанием.\n\nЖелание остаться молодым прозвучало почти как шутка, но в этой шутке уже пряталась судьба: пусть стареет портрет, а живое лицо остается нетронутым.' },
            { id: 'classic-maupin', author: 'Теофиль Готье', title: 'Мадемуазель де Мопен', tag: 'маски и свобода', emoji: '🎭', desc: 'Роман о масках, свободе, любви и праве быть сложным человеком.', text: 'Теофиль Готье — Мадемуазель де Мопен\n\nЕсть души, которым тесно в готовых ролях. Они примеряют маски не ради обмана, а чтобы выяснить, какое лицо останется своим, когда чужие ожидания перестанут давить.\n\nГероиня романа ищет не удобной добродетели и не громкой славы, а права быть сложной. В ее мире красота спорит с моралью, театр — с жизнью, а любовь начинается там, где человек перестает быть понятной схемой.\n\nКаждая встреча похожа на сцену, но занавес не спасает от настоящих чувств.' },
            { id: 'classic-heart', author: 'Эдгар Аллан По', title: 'Сердце-обличитель', tag: 'ночь и вина', emoji: '🫀', desc: 'Мрачный рассказ о вине, страхе и звуке, который невозможно заглушить.', text: 'Эдгар Аллан По — Сердце-обличитель\n\nДа, я был болен, но почему вы называете меня безумцем? Болезнь обострила мои чувства, а не разрушила их. Особенно слух: я слышал многое на земле и в небе, и порой — то, что скрывается глубже.\n\nЯ любил старика. Он никогда не обижал меня. Но его глаз, бледный и неподвижный, преследовал меня, пока одна мысль не стала сильнее сна.\n\nНочью я входил бесшумно, медленно, осторожно. И все же потом, когда дело было сделано, тишину разорвал звук: глухое биение, будто сердце заговорило из-под досок.' },
            { id: 'classic-vurdalak', author: 'Алексей Толстой', title: 'Семья вурдалака', tag: 'готическая легенда', emoji: '🌘', desc: 'Готическая легенда о семье, ожидании и холоде за знакомым голосом.', text: 'Алексей Толстой — Семья вурдалака\n\nПутник прибыл в дом, где ожидание было тяжелее ночи. Старый Горча ушел мстить разбойнику и велел семье: если вернется позднее назначенного часа, не открывать ему дверей, потому что это будет уже не отец.\n\nВ комнате молчали. Дети прислушивались к каждому шороху, женщины крестились, а за окном темнела дорога.\n\nКогда наконец послышались шаги, радость и ужас вошли вместе. Человек у порога был похож на Горчу, говорил его голосом, просил впустить его как родного. Но в просьбе было что-то холодное, от чего кровь становилась тише.' },
            { id: 'classic-jekyll', author: 'Роберт Льюис Стивенсон', title: 'Странная история доктора Джекила и мистера Хайда', tag: 'двойник внутри', emoji: '🧪', desc: 'История о двойнике, скрытых желаниях и опасном эксперименте над собой.', text: 'Роберт Льюис Стивенсон — Странная история доктора Джекила и мистера Хайда\n\nДоктор Джекил был человеком уважаемым, щедрым и образованным. Но он знал о себе то, что тщательно скрывал: в одной душе могут жить разные желания, и не все они готовы подчиняться имени, положению и приличию.\n\nОпыт, задуманный как освобождение, разделил его природу. Появился мистер Хайд — маленький, резкий, неприятный, словно воплощение того, что обычно прячут от света.\n\nСначала превращение казалось победой науки над совестью. Потом стало ясно: отпущенная тень не возвращается в клетку по первому приказу.' },
            { id: 'classic-scarlet', author: 'Джек Лондон', title: 'Алая чума', tag: 'после конца мира', emoji: '🩸', desc: 'Постапокалиптический рассказ о памяти цивилизации после великой эпидемии.', text: 'Джек Лондон — Алая чума\n\nСтарик шел по берегу среди внуков, которые уже не понимали слов прежней цивилизации. Когда-то были города, университеты, корабли и миллионы людей. Потом пришла алая чума.\n\nБолезнь двигалась быстрее страха. Лица краснели, речь путалась, человек падал, и мир, построенный веками, рассыпался за недели.\n\nТеперь дети слушали рассказ как сказку о невозможном прошлом. Но старик помнил улицы, книги, шум машин и то страшное утро, когда стало ясно: знание не всегда успевает спасти тех, кто им гордится.' },
            { id: 'classic-4338', author: 'Владимир Одоевский', title: '4338 год', tag: 'ранняя фантастика', emoji: '🔭', desc: 'Ранняя фантастика о будущем, связи, науке и ответственности человека.', text: 'Владимир Одоевский — 4338 год\n\nБудущее открывалось не как чудо, а как привычный порядок иной эпохи. Люди обменивались вестями на расстоянии, города соединялись быстрыми путями, наука входила в быт так спокойно, будто всегда там была.\n\nНо чем совершеннее становились средства, тем важнее был вопрос: сделался ли человек мудрее?\n\nВ мире 4338 года техника обещает близость, скорость и память. Однако сердце по-прежнему нуждается в выборе, а ум — в ответственности перед тем, что он создает.' },
            { id: 'classic-adam-eve', author: 'Марк Твен', title: 'Дневник Адама и Евы', tag: 'ирония и нежность', emoji: '🍎', desc: 'Нежная и ироничная версия первой любви и первого общего дома.', text: 'Марк Твен — Дневник Адама и Евы\n\nАдам записывает события кратко и с недоумением: новое существо слишком много говорит, дает имена всему вокруг и почему-то считает, что сад станет лучше, если его объяснить.\n\nЕва смотрит на мир иначе. Для нее каждая вещь просит названия, каждый день достоин открытия, а молчаливый спутник кажется загадкой, которую стоит приручить терпением.\n\nИз шутки постепенно рождается нежность: два разных взгляда учатся быть одним домом.' },
            { id: 'classic-devil', author: 'Амброз Бирс', title: 'Словарь Сатаны', tag: 'язвительные определения', emoji: '😈', desc: 'Язвительные определения, которые снимают с привычных слов парадную маску.', text: 'Амброз Бирс — Словарь Сатаны\n\nЦиник — человек, который видит вещи такими, каковы они есть, а не такими, какими им велят быть.\n\nДипломатия — искусство говорить так, чтобы собеседник не заметил, где именно его обвели вокруг смысла.\n\nОпыт — имя, которым люди называют свои ошибки, когда хотят, чтобы они выглядели как образование.\n\nСловарь этот не столько объясняет слова, сколько снимает с них праздничную упаковку.' }
