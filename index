        function loadData() {
            try {
                var raw = localStorage.getItem(STORAGE_KEY);
                if (!raw) return getDefaultData();
                var d = JSON.parse(raw);
                var def = getDefaultData();
                for (var k in def) {
                    if (d[k] === undefined) d[k] = def[k];
                }
                if (typeof d.readingDays === 'string') {
                    try { d.readingDays = JSON.parse(d.readingDays); } catch(e) { d.readingDays = []; }
                }
                if (!Array.isArray(d.books)) d.books = [];
                if (!d.taskClaims) d.taskClaims = {};
                if (!d.taskReady) d.taskReady = {};
                if (!d.builtinProgress) d.builtinProgress = {};
                if (!d.totalReadingDays) d.totalReadingDays = Array.isArray(d.readingDays) ? d.readingDays.length : 0;
                if (!d.petGrowthDays) d.petGrowthDays = d.streak || 0;                d.coins = parseInt(d.coins || 0, 10);
                return d;
            } catch(e) {
                console.error('Load error:', e);
                return getDefaultData();
            }
        }

