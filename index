<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LuminaRead — Читай со звездой</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --accent: #8E77B8;
            --accent-dark: #6F5A98;
            --accent-light: #C7B7DF;
            --accent-pale: #EFE8F7;
            --accent-glow: rgba(111, 90, 152, 0.24);
            --gold: #f0d584;
            --gold-dark: #d4b35a;
            --gold-light: #BFA2E2;
            --gold-pale: #F2ECFA;
            --bg: #F4F0FA;
            --surface: #FFFFFF;
            --surface2: #EEE7F7;
            --surface3: #DED2EF;
            --text: #342B45;
            --text2: #665A78;
            --text3: #9588A8;
            --radius: 20px;
            --shadow: 0 4px 20px rgba(52, 43, 69, 0.08);
            --shadow-lg: 0 8px 40px rgba(52, 43, 69, 0.14);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Nunito', sans-serif;
            background: linear-gradient(180deg, #FFFFFF 0%, #F4F0FA 48%, #ECE5F8 100%);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            -webkit-tap-highlight-color: transparent;
        }

        body.dark-theme {
            --accent: #A895D2;
            --accent-dark: #CDBEF0;
            --accent-light: #75639B;
            --accent-pale: #4B3F63;
            --accent-glow: rgba(155, 134, 200, 0.28);
            --gold: #D8A24B;
            --gold-dark: #FF9800;
            --gold-light: #75639B;
            --gold-pale: #4B3F63;
            --bg: #302742;
            --surface: #3A304D;
            --surface2: #45385A;
            --surface3: #5A4A74;
            --text: #F8F2FF;
            --text2: #E8DFFF;
            --text3: #D0C4EA;
            --shadow: 0 4px 20px rgba(0, 0, 0, 0.28);
            --shadow-lg: 0 8px 40px rgba(0, 0, 0, 0.38);
            background: #302742;
        }

        .app {
            max-width: 480px;
            margin: 0 auto;
            padding: 0 16px 90px;
            position: relative;
        }

        /* Header */
        .header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 0 12px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .logo-icon {
            width: auto;
            height: auto;
            background: transparent;
            border-radius: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            line-height: 1;
        }

        .logo-text {
            font-size: 20px;
            font-weight: 800;
            color: var(--text);
        }

        .streak-badge {
            background: var(--accent-pale);
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 14px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 6px;
            color: var(--accent-dark);
        }

        /* Nav Tabs */
        .nav-tabs {
            display: flex;
            gap: 6px;
            background: var(--surface2);
            border-radius: 14px;
            padding: 4px;
            margin-bottom: 20px;
        }

        .nav-tab {
            flex: 1;
            padding: 10px 7px;
            border: none;
            background: transparent;
            color: var(--text3);
            font-family: inherit;
            font-size: 12px;
            font-weight: 700;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
            -webkit-appearance: none;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            min-height: 58px;
        }

        .nav-icon { font-size: 18px; line-height: 1; }
        .nav-label { line-height: 1.1; }

        .nav-tab.active {
            background: var(--accent);
            color: #FFFDF8;
            box-shadow: 0 4px 12px var(--accent-glow);
        }

        .nav-tab:not(.active):hover {
            color: var(--text2);
            background: var(--surface3);
        }

        /* Pages */
        .page { display: none; }
        .page.active { display: block; animation: fadeIn 0.3s ease; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Dinosaur Display */
        .dino-container {
            background: linear-gradient(180deg, var(--accent-pale) 0%, var(--surface2) 100%);
            border-radius: var(--radius);
            padding: 24px 20px;
            text-align: center;
            margin-bottom: 16px;
            border: 2px solid var(--accent-light);
            position: relative;
            overflow: hidden;
        }

        .dino-container::before {
            content: '';
            position: absolute;
            top: -30%;
            right: -20%;
            width: 120px;
            height: 120px;
            background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
            pointer-events: none;
        }

        .dino-stage {
            font-size: 80px;
            margin: 8px 0;
            animation: dinoFloat 3s ease-in-out infinite;
            display: block;
        }

        @keyframes dinoFloat {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-8px) rotate(2deg); }
        }

        .dino-name {
            font-size: 20px;
            font-weight: 800;
            color: var(--accent-dark);
            margin-bottom: 4px;
        }

        .dino-days-badge {
            display: inline-block;
            background: var(--accent);
            color: #FFFDF8;
            font-size: 14px;
            font-weight: 800;
            padding: 4px 16px;
            border-radius: 20px;
            margin-bottom: 10px;
        }

        .dino-progress-text {
            font-size: 12px;
            color: var(--text3);
            margin-bottom: 10px;
        }

        .dino-growth-bar {
            height: 8px;
            background: var(--surface3);
            border-radius: 4px;
            overflow: hidden;
            max-width: 220px;
            margin: 0 auto;
        }

        .dino-growth-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent), var(--accent-dark));
            border-radius: 4px;
            transition: width 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        }


        .section-card {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 18px;
            border: 2px solid var(--surface3);
            box-shadow: var(--shadow);
            margin-bottom: 16px;
        }
        .section-title { font-size: 15px; font-weight: 800; margin-bottom: 12px; }
        .section-sub { font-size: 12px; color: var(--text3); line-height: 1.4; margin: -6px 0 12px; }
        .pet-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px; position: relative; z-index: 1; }
        .pet-stat { background: rgba(255,255,255,0.65); border: 1px solid var(--accent-light); border-radius: 14px; padding: 10px; text-align: left; }
        .pet-stat-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 7px; font-size: 12px; font-weight: 800; }
        .pet-stat-value { color: var(--accent-dark); }
        .pet-stat-bar { height: 8px; background: var(--surface3); border-radius: 4px; overflow: hidden; }
        .pet-stat-fill { height: 100%; background: linear-gradient(90deg, var(--accent-light), var(--accent-dark)); border-radius: 4px; transition: width 0.6s ease; }
        .pet-strip { display: flex; align-items: center; gap: 14px; background: linear-gradient(180deg, var(--accent-pale) 0%, var(--surface2) 100%); border: 1px solid var(--accent-light); border-radius: var(--radius); padding: 16px; margin-bottom: 16px; box-shadow: var(--shadow); }
        .pet-strip-icon { width: 58px; height: 58px; border-radius: 18px; background: rgba(255,255,255,0.72); display: flex; align-items: center; justify-content: center; font-size: 32px; flex-shrink: 0; }
        .pet-strip-info { flex: 1; min-width: 0; }
        .pet-strip-title { font-size: 16px; font-weight: 900; color: var(--text); margin-bottom: 4px; }
        .pet-strip-sub { font-size: 12px; color: var(--text3); font-weight: 700; margin-bottom: 9px; }
        .pet-strip-bar { height: 8px; background: var(--surface3); border-radius: 99px; overflow: hidden; }
        .pet-strip-fill { height: 100%; width: 0%; border-radius: 99px; background: linear-gradient(90deg, var(--accent), var(--accent-dark)); transition: width .3s ease; }
        .tasks-grid { display: grid; gap: 8px; }
        .task-card { display: flex; justify-content: space-between; gap: 10px; align-items: center; background: var(--surface2); border: 2px solid transparent; border-radius: 14px; padding: 11px 12px; transition: transform .18s ease, background .18s ease, border-color .18s ease; }
        .task-card.ready { background: var(--accent-pale); border-color: var(--accent-light); cursor: pointer; }
        .task-card.ready:hover { transform: translateY(-1px); border-color: var(--accent); }
        .task-card.claimed { background: var(--surface2); color: var(--accent-dark); }
        .task-name { font-size: 13px; font-weight: 800; }
        .task-reward { flex-shrink: 0; font-size: 13px; font-weight: 900; color: #FF9800; white-space: nowrap; background: #FFFFFF; border-radius: 14px; padding: 8px 11px; min-width: 58px; text-align: center; box-shadow: 0 2px 8px rgba(111, 90, 152, 0.08); }
        .task-state { font-size: 12px; font-weight: 800; color: var(--accent-dark); white-space: nowrap; }
        .task-state.locked { color: var(--text3); }
        .task-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
        .spark-fly { position: fixed; z-index: 9999; pointer-events: none; font-size: 18px; font-weight: 900; color: #FF9800; animation: sparkFly .72s cubic-bezier(.22,.9,.26,1) forwards; }
        @keyframes sparkFly { 0% { transform: translate(0,0) scale(1); opacity: 1; } 100% { transform: translate(var(--spark-x), var(--spark-y)) scale(.55); opacity: 0; } }
        .book-card-icon { height: 58px; border-radius: 8px 13px 13px 8px; box-shadow: inset -5px 0 0 rgba(61, 74, 58, 0.08); }


        .book-card-icon {
            width: 50px;
            height: 58px;
            font-size: 26px;
            border-radius: 12px;
            box-shadow: none;
        }
        .book-card-icon::before { content: none; }
        .book-card-author { font-size: 14px; font-weight: 900; color: var(--text); line-height: 1.2; margin-bottom: 2px; }
        .book-card-title { font-size: 15px; font-weight: 800; color: var(--accent-dark); line-height: 1.25; margin-bottom: 5px; }
        .book-card-desc { font-size: 12px; color: var(--text2); line-height: 1.35; margin-bottom: 7px; }
        .book-card-meta { margin-bottom: 7px; }
        .reader-encoding-select {
            background: var(--surface2);
            border: 1px solid var(--surface3);
            color: var(--text2);
            border-radius: 8px;
            padding: 6px 7px;
            font-size: 11px;
            font-weight: 800;
            max-width: 92px;
            outline: none;
        }
        .chart-tabs { display: flex; gap: 6px; background: var(--surface2); border-radius: 12px; padding: 4px; margin-bottom: 14px; }
        .chart-tab { flex: 1; border: none; border-radius: 9px; padding: 8px; background: transparent; color: var(--text3); font-size: 12px; font-weight: 800; cursor: pointer; }
        .chart-tab.active { background: var(--accent); color: #FFFDF8; }
        .month-chart { gap: 3px; overflow-x: auto; padding-bottom: 4px; }
        .month-chart .chart-bar-wrapper { min-width: 12px; }
        .month-chart .chart-bar { max-width: 10px; border-radius: 4px 4px 2px 2px; }
        .month-chart .chart-bar-label { font-size: 8px; }
        .library-controls { display: flex; gap: 8px; margin-bottom: 12px; }
        .library-list { display: grid; gap: 10px; }
        .library-item { background: var(--surface2); border-radius: 14px; padding: 12px; }
        .library-title-row { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-bottom: 8px; }
        .library-title { font-size: 14px; font-weight: 900; }
        .library-delete { border: none; background: transparent; color: var(--text3); font-size: 18px; cursor: pointer; }
        .library-row { display: flex; gap: 8px; margin-bottom: 8px; }
        .library-select {
            flex: 1;
            min-width: 0;
            background: var(--surface);
            border: 2px solid var(--surface3);
            border-radius: 10px;
            padding: 9px 10px;
            font-size: 12px;
            font-weight: 700;
            color: var(--text2);
        }
        .library-books { font-size: 12px; color: var(--text2); line-height: 1.4; margin-bottom: 8px; }
        .library-note {
            width: 100%;
            min-height: 76px;
            resize: vertical;
            background: var(--surface);
            border: 2px solid var(--surface3);
            border-radius: 10px;
            padding: 10px;
            font-size: 13px;
            color: var(--text);
            outline: none;
        }
        .library-note:focus { border-color: var(--accent); }

        @media (max-width: 380px) { .pet-stats { grid-template-columns: 1fr; } }

        /* Timer Card */
        .timer-card {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 24px;
            text-align: center;
            border: 2px solid var(--surface3);
            box-shadow: var(--shadow);
            margin-bottom: 16px;
        }

        .timer-label-text {
            font-size: 12px;
            color: var(--text3);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 10px;
        }

        .timer-display {
            font-size: 56px;
            font-weight: 900;
            font-variant-numeric: tabular-nums;
            color: var(--text);
            line-height: 1;
            margin: 8px 0;
            transition: color 0.3s;
        }

        .timer-display.running { color: var(--accent-dark); }

        .timer-session-info {
            font-size: 13px;
            color: var(--text3);
            margin-bottom: 20px;
            min-height: 20px;
        }

        .timer-buttons {
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        .btn {
            border: none;
            font-family: inherit;
            font-weight: 700;
            border-radius: 14px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            -webkit-appearance: none;
        }

        .btn:active { transform: scale(0.96); }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent), var(--accent-dark));
            color: #FFFDF8;
            padding: 14px 32px;
            font-size: 15px;
            box-shadow: 0 6px 20px var(--accent-glow);
        }

        .btn-primary:hover { box-shadow: 0 8px 28px var(--accent-glow); transform: translateY(-1px); }

        .btn-primary.running {
            background: linear-gradient(135deg, #7D68A8, #5E4B86);
            box-shadow: 0 6px 20px rgba(94, 75, 134, 0.28);
        }

        .btn-secondary {
            background: var(--surface2);
            color: var(--text2);
            padding: 14px 18px;
            font-size: 13px;
            border: 2px solid var(--surface3);
        }

        .btn-secondary:hover { background: var(--surface3); }

        /* Goal Card */
        .goal-card {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 18px;
            margin-bottom: 16px;
            border: 2px solid var(--surface3);
            box-shadow: var(--shadow);
        }

        .goal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .goal-title { font-size: 15px; font-weight: 700; }

        .goal-edit {
            background: var(--accent-pale);
            border: none;
            color: var(--accent-dark);
            padding: 6px 12px;
            border-radius: 8px;
            font-family: inherit;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
        }

        .goal-progress-bar {
            height: 12px;
            background: var(--surface2);
            border-radius: 6px;
            overflow: hidden;
            margin-bottom: 10px;
        }

        .goal-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-light), var(--accent-dark));
            border-radius: 6px;
            transition: width 0.5s ease;
        }

        .goal-progress-fill.complete { background: linear-gradient(90deg, var(--accent), var(--accent-dark)); }

        .goal-stats { display: flex; justify-content: space-between; font-size: 13px; }
        .goal-stats .current { color: var(--text); font-weight: 800; }
        .goal-stats .target { color: var(--text3); }

        /* Quick Add */
        .quick-add {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 18px;
            border: 2px solid var(--surface3);
            box-shadow: var(--shadow);
        }

        .quick-add-title { font-size: 14px; font-weight: 700; margin-bottom: 12px; }

        .quick-add-buttons { display: flex; gap: 8px; flex-wrap: wrap; }

        .quick-btn {
            background: var(--accent-pale);
            border: 2px solid var(--accent-light);
            color: var(--accent-dark);
            padding: 8px 16px;
            border-radius: 10px;
            font-family: inherit;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            -webkit-appearance: none;
        }

        .quick-btn:hover { background: var(--accent-light); transform: translateY(-2px); }
        .quick-btn:active { transform: scale(0.95); }

        .custom-add { display: flex; gap: 8px; margin-top: 10px; }

        .custom-input {
            flex: 1;
            background: var(--surface2);
            border: 2px solid var(--surface3);
            color: var(--text);
            padding: 10px 14px;
            border-radius: 10px;
            font-family: inherit;
            font-size: 14px;
            font-weight: 600;
            outline: none;
            -webkit-appearance: none;
        }

        .custom-input:focus { border-color: var(--accent); }

        .custom-add-btn {
            background: var(--accent);
            border: none;
            color: #FFFDF8;
            padding: 10px 18px;
            border-radius: 10px;
            font-family: inherit;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            -webkit-appearance: none;
        }

        /* Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 16px;
        }

        .stat-card {
            background: var(--surface);
            border-radius: 16px;
            padding: 16px;
            border: 2px solid var(--surface3);
            text-align: center;
            box-shadow: var(--shadow);
        }

        .stat-icon { font-size: 22px; margin-bottom: 6px; display: block; }
        .stat-value { font-size: 24px; font-weight: 900; line-height: 1.1; }
        .stat-label { font-size: 11px; color: var(--text3); font-weight: 600; margin-top: 4px; }

        .stat-card.total .stat-value { color: var(--accent-dark); }
        .stat-card.today .stat-value { color: var(--accent); }
        .stat-card.streak .stat-value { color: #FF9800; }
        .stat-card.sessions .stat-value { color: #FF9800; }

        /* Weekly Chart */
        .chart-card {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 18px;
            margin-bottom: 16px;
            border: 2px solid var(--surface3);
            box-shadow: var(--shadow);
        }

        .chart-title { font-size: 14px; font-weight: 700; margin-bottom: 14px; }

        .chart-bars {
            display: flex;
            align-items: flex-end;
            gap: 6px;
            height: 90px;
        }

        .chart-bar-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            height: 100%;
            justify-content: flex-end;
        }

        .chart-bar-value { font-size: 9px; color: var(--text3); font-weight: 700; margin-bottom: 3px; }

        .chart-bar {
            width: 100%;
            max-width: 28px;
            background: linear-gradient(180deg, var(--accent-light), var(--accent));
            border-radius: 5px 5px 3px 3px;
            transition: height 0.5s ease;
            min-height: 3px;
        }

        .chart-bar.today-bar { background: linear-gradient(180deg, var(--accent), var(--accent-dark)); }

        .chart-bar-label { font-size: 10px; color: var(--text3); font-weight: 700; margin-top: 6px; }

        /* History */
        .history-card {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 18px;
            border: 2px solid var(--surface3);
            box-shadow: var(--shadow);
        }

        .history-title { font-size: 14px; font-weight: 700; margin-bottom: 12px; }

        .history-list {
            display: flex;
            flex-direction: column;
            gap: 6px;
            max-height: 250px;
            overflow-y: auto;
        }

        .history-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 12px;
            background: var(--surface2);
            border-radius: 10px;
        }

        .history-item-left { display: flex; align-items: center; gap: 8px; }

        .history-item-icon {
            width: 28px;
            height: 28px;
            background: var(--accent-pale);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
        }

        .history-item-time { font-size: 12px; font-weight: 700; }
        .history-item-date { font-size: 10px; color: var(--text3); }
        .history-item-minutes { font-size: 13px; font-weight: 800; color: var(--accent-dark); }

        /* Achievements - Redesigned */
        .achievements-header { text-align: center; margin-bottom: 20px; }
        .achievements-count { font-size: 13px; color: var(--text3); margin-top: 6px; }
        .achievements-count span { color: var(--accent-dark); font-weight: 800; }

        /* Section title centered */
        .achievement-section-header {
            text-align: center;
            margin: 24px 0 14px;
            position: relative;
        }

        .achievement-section-header::before,
        .achievement-section-header::after {
            content: '';
            position: absolute;
            top: 50%;
            height: 1px;
            background: var(--surface3);
            width: calc(50% - 80px);
        }

        .achievement-section-header::before { left: 0; }
        .achievement-section-header::after { right: 0; }

        .achievement-section-title {
            display: inline-block;
            font-size: 13px;
            color: var(--text2);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            background: var(--bg);
            padding: 0 16px;
