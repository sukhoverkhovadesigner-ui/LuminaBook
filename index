        // ===== ADD MINUTES =====
        function addMinutes(minutes, fromTimer) {
            if (minutes <= 0) return;

            checkDayReset();
            var previousToday = appData.todayMinutes;
            appData.totalMinutes += minutes;
            appData.todayMinutes += minutes;

            var today = getTodayKey();
            if (!appData.weeklyData[today]) appData.weeklyData[today] = 0;
            appData.weeklyData[today] += minutes;

            if (!appData.readingDays) appData.readingDays = [];
            if (appData.readingDays.indexOf(today) === -1) appData.readingDays.push(today);
            appData.totalReadingDays = appData.readingDays.length;
            appData.petGrowthDays = Math.max(appData.petGrowthDays || 0, appData.totalReadingDays || 0);

            if (appData.todayMinutes >= appData.dailyGoal) {
                updateStreak(today);
            }

            appData.sessions.unshift({
                date: today,
                type: 'reading',
                minutes: minutes,
                timestamp: Date.now(),
                fromTimer: !!fromTimer
            });

            if (appData.sessions.length > 100) appData.sessions = appData.sessions.slice(0, 100);
            applyPetRewards(minutes, previousToday);

            saveData();
            updateUI();
            checkAchievements();

            if (appData.todayMinutes >= appData.dailyGoal && (appData.todayMinutes - minutes) < appData.dailyGoal) {
                showToast('🎉 Дневная цель достигнута!');
            }
        }

        function updateStreak(today) {
            var todayStreak = null;
            for (var i = 0; i < appData.sessions.length; i++) {
                if (appData.sessions[i].date === today && appData.sessions[i].type === 'streak') {
                    todayStreak = appData.sessions[i];
                    break;
                }
            }
            if (!todayStreak) {
                var yesterday = new Date();
                yesterday.setDate(yesterday.getDate() - 1);
                var yesterdayKey = yesterday.toISOString().slice(0, 10);

                if (appData.readingDays && appData.readingDays.indexOf(yesterdayKey) !== -1) {
                    appData.streak++;
                } else {
                    appData.streak = 1;
                }
                appData.totalReadingDays = appData.readingDays ? appData.readingDays.length : appData.totalReadingDays;
                appData.petGrowthDays = Math.max(appData.petGrowthDays || 0, appData.totalReadingDays || 0);

                appData.sessions.push({ date: today, type: 'streak', minutes: 0, timestamp: Date.now() });
            }
        }

