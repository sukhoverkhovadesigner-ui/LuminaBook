        async function makeBookFromFile(file) {
            var buffer = await file.arrayBuffer();
            var ext = (file.name.split('.').pop() || '').toLowerCase();
            var encodingMode = document.getElementById('encodingSelect').value;
            var result;
            if (ext === 'fb2') result = parseFb2(buffer, 'auto');
            else if (ext === 'pdf') result = await parsePdf(buffer);
            else if (ext === 'epub') result = await parseEpub(buffer);
            else result = decodeBuffer(buffer, encodingMode);
            var clean = normalizeBookText(result.text);
            if (!clean || clean.length < 20) {
                clean = ext === 'pdf' ? 'PDF будет открыт в новой вкладке.' : 'Текст не удалось извлечь полностью. Файл добавлен как карточка; попробуй загрузить TXT или FB2-версию этой книги для комфортного чтения.';
            }
            var bookId = 'user-' + Date.now() + '-' + Math.random().toString(36).substr(2, 8);
            if (ext === 'pdf') {
                pdfSessionUrls[bookId] = URL.createObjectURL(new Blob([buffer], { type: 'application/pdf' }));
            }
            return {
                id: bookId,
                name: file.name.replace(/\.(epub|pdf|txt|text|fb2)$/i, ''),
                author: 'Пользовательская книга',
                title: file.name.replace(/\.(epub|pdf|txt|text|fb2)$/i, ''),
                desc: 'Пользовательская книга',
                emoji: getFormatEmoji(ext),
                rawBase64: (ext === 'fb2' || ext === 'txt' || ext === 'text' || ext === 'pdf') && buffer.byteLength < 3500000 ? arrayBufferToBase64(buffer) : null,
                rawFormat: ext,
                externalOpen: ext === 'pdf',
                pages: splitIntoPages(clean, 900),
                currentPage: 0,
                totalWords: clean.split(/\s+/).filter(function(w){ return w.length > 0; }).length,
                encoding: result.encoding || ext.toUpperCase(),
                addedDate: getTodayKey(),
                lastRead: null,
                userBook: true
            };
        }


        function arrayBufferToBase64(buffer) {
            var bytes = new Uint8Array(buffer);
            var binary = '';
            for (var i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
            return btoa(binary);
        }

        function base64ToArrayBuffer(base64) {
            var binary = atob(base64);
            var bytes = new Uint8Array(binary.length);
            for (var i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
            return bytes.buffer;
        }

        function getFormatEmoji(ext) {
            if (ext === 'pdf') return '📄';
            if (ext === 'epub') return '📘';
            if (ext === 'fb2') return '📗';
            return '📕';
        }

        function parseFb2(buffer, encodingMode) {
            var decoded = decodeBuffer(buffer, encodingMode);
            var xml = new DOMParser().parseFromString(decoded.text, 'text/xml');
            var bodies = Array.prototype.slice.call(xml.getElementsByTagName('body'));
            var text = bodies.map(function(body) { return body.textContent || ''; }).join('\n\n');
            return { text: text || decoded.text.replace(/<[^>]+>/g, ' '), encoding: decoded.encoding };
        }

        async function parsePdf(buffer) {
            var raw = new TextDecoder('latin1').decode(buffer);
            var chunks = [];

            function collectText(str) {
                var parts = [];
                var literal = str.match(/\((?:\\.|[^\\)]){2,}\)/g) || [];
                for (var i = 0; i < literal.length; i++) {
                    parts.push(literal[i].slice(1, -1).replace(/\\\)/g, ')').replace(/\\\(/g, '(').replace(/\\n/g, ' '));
                }
                var hex = str.match(/<([0-9A-Fa-f\s]{4,})>/g) || [];
                for (var j = 0; j < hex.length; j++) {
                    var clean = hex[j].replace(/[<>\s]/g, '');
                    var out = '';
                    for (var k = 0; k < clean.length; k += 4) {
                        var code = parseInt(clean.substr(k, 4), 16);
                        if (code && code < 65535) out += String.fromCharCode(code);
                    }
                    parts.push(out);
                }
                return parts.join(' ');
            }

            chunks.push(collectText(raw));
            var streams = raw.match(/stream\r?\n[\s\S]*?\r?\nendstream/g) || [];
            for (var i = 0; i < Math.min(streams.length, 80); i++) {
                var block = streams[i].replace(/^stream\r?\n/, '').replace(/\r?\nendstream$/, '');
                try {
                    var bytes = new Uint8Array(block.length);
                    for (var b = 0; b < block.length; b++) bytes[b] = block.charCodeAt(b) & 255;
                    if (typeof DecompressionStream !== 'undefined') {
                        var inflated = await new Response(new Blob([bytes]).stream().pipeThrough(new DecompressionStream('deflate'))).arrayBuffer();
                        chunks.push(collectText(new TextDecoder('latin1').decode(inflated)));
                    }
                } catch(e) {}
            }
            var text = normalizeBookText(chunks.join(' '));
            return { text: text || 'PDF будет открыт в новой вкладке.', encoding: 'PDF' };
        }

        async function parseEpub(buffer) {
            try {
                var entries = readZipEntries(buffer);
                var textEntries = entries.filter(function(e) { return /\.(xhtml|html|htm|txt)$/i.test(e.name); });
                var chunks = [];
                for (var i = 0; i < Math.min(textEntries.length, 30); i++) {
                    var bytes = await inflateZipEntry(buffer, textEntries[i]);
                    chunks.push(stripHtml(new TextDecoder('utf-8').decode(bytes)));
                }
                return { text: chunks.join('\n\n'), encoding: 'EPUB' };
            } catch(e) {
                return { text: 'EPUB загружен, но этот файл не удалось распаковать встроенным чтением. Попробуй TXT или FB2-версию.', encoding: 'EPUB' };
            }
        }

        function readZipEntries(buffer) {
            var view = new DataView(buffer);
            var entries = [];
            for (var p = 0; p < view.byteLength - 46; p++) {
                if (view.getUint32(p, true) === 0x02014b50) {
                    var method = view.getUint16(p + 10, true);
                    var compressedSize = view.getUint32(p + 20, true);
                    var nameLen = view.getUint16(p + 28, true);
                    var extraLen = view.getUint16(p + 30, true);
                    var commentLen = view.getUint16(p + 32, true);
                    var localOffset = view.getUint32(p + 42, true);
                    var name = new TextDecoder('utf-8').decode(new Uint8Array(buffer, p + 46, nameLen));
                    entries.push({ name: name, method: method, compressedSize: compressedSize, localOffset: localOffset });
                    p += 45 + nameLen + extraLen + commentLen;
                }
            }
            return entries;
        }

        async function inflateZipEntry(buffer, entry) {
            var view = new DataView(buffer, entry.localOffset);
            var nameLen = view.getUint16(26, true);
            var extraLen = view.getUint16(28, true);
            var start = entry.localOffset + 30 + nameLen + extraLen;
            var compressed = new Uint8Array(buffer, start, entry.compressedSize);
            if (entry.method === 0) return compressed;
            if (entry.method !== 8 || typeof DecompressionStream === 'undefined') throw new Error('unsupported zip method');
            var stream = new Blob([compressed]).stream().pipeThrough(new DecompressionStream('deflate-raw'));
            return new Uint8Array(await new Response(stream).arrayBuffer());
        }

        function stripHtml(text) {
            return (text || '').replace(/<script[\s\S]*?<\/script>/gi, ' ').replace(/<style[\s\S]*?<\/style>/gi, ' ').replace(/<[^>]+>/g, ' ').replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>');
        }

        function normalizeBookText(text) {
            return stripHtml(text).replace(/\r\n/g, '\n').replace(/\r/g, '\n').replace(/[ \t]+/g, ' ').replace(/\n{3,}/g, '\n\n').trim();
        }

        function splitIntoPages(text, charsPerPage) {
            var pages = [];
            var remaining = text.trim();
            while (remaining.length > 0) {
                if (remaining.length <= charsPerPage) {
                    pages.push(remaining.trim());
                    break;
                }
                var splitPoint = remaining.lastIndexOf('.', charsPerPage);
                if (splitPoint < charsPerPage * 0.5) splitPoint = remaining.lastIndexOf('\n', charsPerPage);
                if (splitPoint < charsPerPage * 0.5) splitPoint = charsPerPage;
                pages.push(remaining.substring(0, splitPoint + 1).trim());
                remaining = remaining.substring(splitPoint + 1).trim();
            }
            return pages.filter(function(p) { return p.length > 0; });
        }

        function getAllBooks() {
            var userBooks = (appData.books || []).map(function(book) {
                book.author = book.userBook ? 'Пользовательская книга' : (book.author || 'Автор неизвестен');
                book.title = book.title || book.name || 'Без названия';
                book.desc = book.desc || 'Пользовательская книга';
                book.emoji = book.emoji || '📕';
                return book;
            });
            var builtIns = BUILT_IN_BOOKS.map(function(book) {
                var pages = splitIntoPages(book.text, 900);
                var currentPage = (appData.builtinProgress && appData.builtinProgress[book.id]) || 0;
                return {
                    id: book.id,
                    name: book.author + ' — «' + book.title + '»',
                    author: book.author,
                    title: book.title,
                    desc: book.desc,
                    emoji: book.emoji,
                    pages: pages,
                    currentPage: Math.min(currentPage, pages.length - 1),
                    totalWords: book.text.split(/\s+/).filter(function(w){ return w.length > 0; }).length,
                    encoding: book.tag,
                    builtIn: true
                };
            });
            return userBooks.concat(builtIns);
        }

