        // ===== ENCODING =====
        function detectEncoding(buffer) {
            var bytes = new Uint8Array(buffer);
            if (bytes[0] === 0xEF && bytes[1] === 0xBB && bytes[2] === 0xBF) return 'UTF-8';
            if (bytes[0] === 0xFF && bytes[1] === 0xFE) return 'UTF-16LE';
            try {
                var utf8Text = new TextDecoder('UTF-8', { fatal: true }).decode(bytes.slice(0, 800));
                if ((utf8Text.match(/[а-яА-ЯёЁ]/g) || []).length > 8) return 'UTF-8';
            } catch(e) {}
            try {
                var cp1251Text = new TextDecoder('windows-1251').decode(bytes.slice(0, 800));
                if ((cp1251Text.match(/[а-яА-ЯёЁ]/g) || []).length > 8) return 'windows-1251';
            } catch(e) {}
            return 'UTF-8';
        }

        function scoreDecodedText(text) {
            var cyr = (text.match(/[а-яА-ЯёЁ]/g) || []).length;
            var bad = (text.match(/[�]/g) || []).length;
            var tags = (text.match(/<[^>]+>/g) || []).length;
            return cyr * 3 + tags - bad * 20;
        }

        function decodeBuffer(buffer, encodingMode) {
            if (encodingMode && encodingMode !== 'auto') {
                var forced = encodingMode === 'windows-1251' ? 'windows-1251' :
                             encodingMode === 'KOI8-R' ? 'koi8-r' :
                             encodingMode === 'ISO-8859-5' ? 'iso-8859-5' :
                             encodingMode === 'UTF-16LE' ? 'utf-16le' : 'utf-8';
                return { text: new TextDecoder(forced).decode(buffer), encoding: encodingMode };
            }
            var bytes = new Uint8Array(buffer);
            var head = new TextDecoder('latin1').decode(bytes.slice(0, 300));
            var declared = head.match(/encoding=["']([^"']+)["']/i);
            var candidates = declared ? [declared[1]] : [];
            candidates = candidates.concat(['UTF-8', 'windows-1251', 'KOI8-R', 'ISO-8859-5', 'UTF-16LE']);
            var best = { text: '', encoding: 'UTF-8', score: -Infinity };
            for (var i = 0; i < candidates.length; i++) {
                try {
                    var label = candidates[i];
                    var encName = /1251/i.test(label) ? 'windows-1251' :
                                  /koi8/i.test(label) ? 'koi8-r' :
                                  /8859-5/i.test(label) ? 'iso-8859-5' :
                                  /utf-16/i.test(label) ? 'utf-16le' : 'utf-8';
                    var text = new TextDecoder(encName).decode(buffer);
                    var score = scoreDecodedText(text);
                    if (score > best.score) best = { text: text, encoding: label, score: score };
                } catch(e) {}
            }
            return { text: best.text, encoding: best.encoding };
        }

